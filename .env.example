# =====================================================================
#  FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT
# =====================================================================
#
#  Comment l'utiliser :
#  1. Fais une COPIE de ce fichier et renomme la copie en ".env.local"
#  2. Remplis chaque valeur avec tes vraies clés (voir le README.md)
#  3. NE PARTAGE JAMAIS ".env.local" (il contient tes secrets)
#
#  ⚠️ Le site FONCTIONNE même si ces valeurs sont vides : il affichera
#     alors des données de démonstration. Remplis-les pour activer la
#     vraie base de données, la connexion et le paiement.
# =====================================================================

# ---------- SUPABASE (base de données + connexion) ----------
# Tu les trouves dans : Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service role" (SECRÈTE) — utilisée UNIQUEMENT côté serveur (webhook Stripe)
SUPABASE_SERVICE_ROLE_KEY=

# ---------- STRIPE (paiement) ----------
# Tu les trouves dans : Stripe → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret du webhook — voir README (Stripe → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=
# Prix en centimes (1000 = 10,00 €). Tu peux le changer ici.
NEXT_PUBLIC_PREMIUM_PRICE_EUR=10

# ---------- SITE ----------
# L'adresse publique de ton site (sans / à la fin).
# En local : http://localhost:3000 — En production : https://ton-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

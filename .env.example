# =====================================================================
#  FICHIER D'EXEMPLE DES VARIABLES D'ENVIRONNEMENT
# =====================================================================
#
#  Comment l'utiliser :
#  1. Fais une COPIE de ce fichier et renomme la copie en ".env.local"
#  2. Remplis chaque valeur avec tes vraies clés (voir le README.md)
#  3. NE PARTAGE JAMAIS ".env.local" (il contient tes secrets)
#
#  ⚠️ Le site FONCTIONNE même si ces valeurs sont vides : il affichera
#     alors des données de démonstration. Le site est 100% gratuit :
#     il n'y a AUCUN système de paiement à configurer.
# =====================================================================

# ---------- SUPABASE (base de données + connexion, optionnel) ----------
# Tu les trouves dans : Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé "service role" (SECRÈTE) — utilisée uniquement côté serveur
SUPABASE_SERVICE_ROLE_KEY=

# ---------- SOUTIEN (Tipeee, optionnel) ----------
# Lien de ta page Tipeee (utilisé par la page "Soutenir le projet").
NEXT_PUBLIC_TIPEEE_URL=https://fr.tipeee.com/

# ---------- SITE ----------
# L'adresse publique de ton site (sans / à la fin).
# En local : http://localhost:3000 — En production : https://ton-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
